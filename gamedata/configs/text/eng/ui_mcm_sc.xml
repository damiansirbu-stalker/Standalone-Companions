	<string id="ui_mcm_sc_anna_btn_teleport">
		<text>Teleport to Me</text>
	</string>
	<string id="ui_mcm_sc_anna_btn_teleport_desc">
		<text>Teleport Anna to your current location. Creates her if she doesn't exist.</text>
	</string>

	<string id="ui_mcm_sc_anna_btn_goto">
		<text>Go to Anna</text>
	</string>
	<string id="ui_mcm_sc_anna_btn_goto_desc">
		<text>Teleport yourself to Anna's current location. Find where she wandered off to.</text>
	</string>

	<string id="ui_mcm_sc_anna_btn_reset_death">
		<text>Reset Death Status</text>
	</string>
	<string id="ui_mcm_sc_anna_btn_reset_death_desc">
		<text>Clear Anna's permadeath flag. Debug only.</text>
	</string>

	<string id="ui_mcm_sc_mila_btn_teleport">
		<text>Teleport to Me</text>
	</string>
	<string id="ui_mcm_sc_mila_btn_teleport_desc">
