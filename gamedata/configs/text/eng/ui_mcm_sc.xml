	<string id="ui_mcm_sc_anna_enabled">
		<text>Enable Anna</text>
	</string>
	<string id="ui_mcm_sc_anna_enabled_desc">
		<text>Allow Anna to exist in the game world.</text>
	</string>

	<string id="ui_mcm_sc_anna_auto_spawn">
		<text>Auto-Spawn</text>
	</string>
	<string id="ui_mcm_sc_anna_auto_spawn_desc">
