	</string>

	<string id="ui_mcm_sc_mila_enabled">
		<text>Enable Mila</text>
	</string>
	<string id="ui_mcm_sc_mila_enabled_desc">
		<text>Allow Mila to exist in the game world.</text>
	</string>

	<string id="ui_mcm_sc_mila_auto_spawn">
		<text>Auto-Spawn</text>
	</string>
	<string id="ui_mcm_sc_mila_auto_spawn_desc">
		<text>Automatically spawn Mila at Dead City if she doesn't exist.</text>
	</string>

