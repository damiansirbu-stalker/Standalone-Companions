	</string>

	<string id="ui_mcm_sc_mila_title">
		<text>Mila (Mercenary)</text>
	</string>
	<string id="ui_mcm_sc_mila_desc">
		<text>Mercenary. Spawns at Dead City. Costs 100,000 rubles to hire.</text>
	</string>

