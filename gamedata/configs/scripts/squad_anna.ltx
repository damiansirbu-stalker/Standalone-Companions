; Anna squad logic - stays where spawned, no hardcoded positions

[logic@base]
post_combat_time = 0,0
net_spawn = pt1

[logic@idle]:logic@base
suitable = true
active = beh@idle
prior = 100

[beh@idle]
target = nil
meet = meet@base
gather_items_enabled = false
help_wounded_enabled = false
corpse_detection_enabled = false
danger_ignore = true

[meet@base]
close_snd_hello = meet_hello
close_snd_bye = nil
close_anim = guard_na
close_victim = actor
close_distance = 3
far_anim = nil
far_victim = nil
far_distance = 0
meet_on_talking = false
use = true
