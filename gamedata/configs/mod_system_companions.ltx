disp_stand_stand		= 0.4
disp_stand_crouch		= 0.35
disp_stand_stand_zoom	= 0.10
disp_stand_crouch_zoom	= 0.08

MinMissDistance			= 0.10
MinMissFactor			= 0.003
MaxMissDistance			= 0.8
MaxMissFactor			= 0.010

[stalker_immunities_mila]
